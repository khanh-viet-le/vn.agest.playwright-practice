{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@fixtures/*": ["src/fixtures/*.fixture.ts"],
      "@models/*": [
        "src/data-objects/*.model.ts", 
        "src/data-objects/*.type.ts", 
        "src/data-objects/*.interface.ts", 
        "src/data-objects/*.enum.ts"
      ],
      "@pages/*": ["src/page-objects/*.page.ts"],
      "@components/*": ["src/page-objects/components/*.component.ts"],
      "@datas/*": ["test-datas/*.data.ts", "test-datas/*.data.json"],
      "@common/*": ["src/common/*.ts"],
      "@helpers/*": ["src/common/helpers/*.helper.ts"]
    },
    "types": ["node"],
  },
  "include": [
    "src/fixtures/**/*.ts", 
    "src/common/**/*.ts", 
    "src/data-objects/**/*.ts", 
    "src/page-objects/**/*.ts", 
    "test-datas/**/*.ts", 
    "test-datas/**/*.json", 
    "tests/**/*.ts", 
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
